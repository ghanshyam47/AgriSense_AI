# ===========================================
# AgriSense Backend Environment Variables
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/agrisense

# Redis
REDIS_URL=redis://localhost:6379

# Gemini AI (REQUIRED — get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap (optional — mock data used if empty)
OPENWEATHER_API_KEY=

# JWT
JWT_SECRET=agrisense-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ML Service
ML_SERVICE_URL=http://localhost:5000

# CORS
CORS_ORIGIN=http://localhost:5173
